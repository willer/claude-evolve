#!/usr/bin/env bash
# claude-evolve-check - Health check for AI model configurations
# Tests all configured AI models to verify they're working before starting evolution runs
#
# AIDEV-NOTE: Uses call_ai_model_configured from ai-cli.sh directly instead of
# maintaining a duplicate case statement. Single source of truth for model commands.

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

# Source configuration and ai-cli to get model lists and call function
source "$LIB_DIR/config.sh"
load_config
source "$LIB_DIR/ai-cli.sh"

# Test timeout in seconds
TEST_TIMEOUT=30

# Simple test prompt
TEST_PROMPT="Say hello in exactly 3 words."

# Temp files
TEMP_OUTPUT=$(mktemp)
trap "rm -f $TEMP_OUTPUT" EXIT

echo -e "${CYAN}🔍 Claude Evolve - AI Model Health Check${NC}"
echo "============================================"
echo

# Collect all unique models into a simple list
ALL_MODELS=""
for model in $LLM_RUN $LLM_RUN_FALLBACK $LLM_IDEATE $LLM_IDEATE_FALLBACK; do
  if ! echo "$ALL_MODELS" | grep -q -w "$model"; then
    ALL_MODELS="$ALL_MODELS $model"
  fi
done
ALL_MODELS=$(echo "$ALL_MODELS" | xargs)

echo "Models to test: $ALL_MODELS"
echo

# Track results
PASSED=0
FAILED=0
FAILED_MODELS=""
TIMEOUT_MODELS=""

# Test a single model using call_ai_model_configured from ai-cli.sh
test_model() {
  local model="$1"
  local prompt="$2"
  local outfile="$3"
  local max_wait="$4"

  # Run call_ai_model_configured in background, capture output to file
  call_ai_model_configured "$model" "$prompt" > "$outfile" 2>&1 &
  local pid=$!

  # Poll for completion
  local elapsed=0
  while kill -0 "$pid" 2>/dev/null; do
    if [[ $elapsed -ge $max_wait ]]; then
      kill "$pid" 2>/dev/null
      sleep 1
      kill -9 "$pid" 2>/dev/null
      wait "$pid" 2>/dev/null
      return 124
    fi
    sleep 1
    ((elapsed++))
  done

  wait "$pid"
  return $?
}

# Test each model
for model in $ALL_MODELS; do
  echo -n "Testing $model... "

  START_TIME=$(date +%s)

  set +e
  test_model "$model" "$TEST_PROMPT" "$TEMP_OUTPUT" "$TEST_TIMEOUT"
  EXIT_CODE=$?
  set -e

  END_TIME=$(date +%s)
  DURATION=$((END_TIME - START_TIME))

  # Read output
  OUTPUT=$(cat "$TEMP_OUTPUT" 2>/dev/null || true)
  OUTPUT_LEN=${#OUTPUT}

  # Check result
  if [[ $EXIT_CODE -eq 0 ]] && [[ -n "$OUTPUT" ]] && [[ $OUTPUT_LEN -gt 10 ]]; then
    echo -e "${GREEN}✓ OK${NC} (${DURATION}s, ${OUTPUT_LEN} chars)"
    ((PASSED++))
  elif [[ $EXIT_CODE -eq 124 ]]; then
    echo -e "${RED}✗ TIMEOUT${NC} (${TEST_TIMEOUT}s)"
    TIMEOUT_MODELS="$TIMEOUT_MODELS $model"
    ((FAILED++))
  else
    echo -e "${RED}✗ FAILED${NC} (exit=$EXIT_CODE, ${OUTPUT_LEN} chars)"
    if [[ -n "$OUTPUT" ]] && [[ $OUTPUT_LEN -lt 200 ]]; then
      echo "    Output: $OUTPUT"
    fi
    FAILED_MODELS="$FAILED_MODELS $model"
    ((FAILED++))
  fi
done

echo
echo "============================================"
echo -e "${CYAN}Summary${NC}"
echo "============================================"
echo -e "Passed: ${GREEN}$PASSED${NC}"
echo -e "Failed: ${RED}$FAILED${NC}"
echo

# Show model lists with status
echo "Model Configuration:"
echo -e "  LLM_RUN: $LLM_RUN"
echo -e "  LLM_RUN_FALLBACK: $LLM_RUN_FALLBACK"
echo -e "  LLM_IDEATE: $LLM_IDEATE"
echo -e "  LLM_IDEATE_FALLBACK: $LLM_IDEATE_FALLBACK"
echo

# Recommendations
if [[ $FAILED -gt 0 ]]; then
  echo -e "${YELLOW}⚠️  Recommendations:${NC}"
  for model in $TIMEOUT_MODELS; do
    echo "  - $model: Check for permission dialogs (try running interactively first)"
  done
  for model in $FAILED_MODELS; do
    echo "  - $model: Check authentication and CLI installation"
  done
  echo
  echo "Consider reordering your model lists to put working models first."
  exit 1
else
  echo -e "${GREEN}✅ All models are working!${NC}"
  exit 0
fi
